{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calendar Copilot",
  "version": "0.1.0",
  "identifier": "com.calendarcopilot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:desktop:web",
    "frontendDist": "../desktop-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Calendar Copilot",
        "width": 1240,
        "height": 900,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
