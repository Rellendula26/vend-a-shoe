DESKTOP_APP_URL=https://your-calendar-copilot-web-url.example.com
DESKTOP_WATCHER_ENDPOINT=https://your-calendar-copilot-web-url.example.com/api/desktop/watcher/tick
DESKTOP_WATCHER_TOKEN=replace-with-long-random-shared-token

# Tauri updater metadata (required for release scripts)
TAURI_UPDATER_ENDPOINT=https://your-update-host.example.com/{{target}}/{{arch}}/{{current_version}}
TAURI_UPDATER_PUBKEY=

# macOS signing + notarization
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Team Name (TEAMID1234)
APPLE_PROVIDER_SHORT_NAME=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# Windows signing (optional scaffold)
WINDOWS_CERTIFICATE_THUMBPRINT=
WINDOWS_TIMESTAMP_URL=http://timestamp.digicert.com
